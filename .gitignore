# =============================================
# AI 教学智能体 - .gitignore
# 原则: 只保留"别人克隆下来能直接跑"所需的文件
# =============================================

# ---------- Python 通用垃圾 ----------
__pycache__/
*.py[cod]
*$py.class
*.pyo
venv/
.env
.pytest_cache/

# ---------- 编辑器/IDE ----------
.idea/
.vscode/
.trae/
.gemini/
.agents/
